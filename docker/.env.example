# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI Embeddings
AZURE_EMBEDDING_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_EMBEDDING_OPENAI_API_KEY=your-api-key-here
AZURE_EMBEDDING_OPENAI_DEPLOYMENT=text-embedding-3-small
AZURE_EMBEDDING_OPENAI_API_VERSION=2024-02-15-preview

# Application Settings
LOG_LEVEL=INFO
SESSION_RETENTION_DAYS=10
